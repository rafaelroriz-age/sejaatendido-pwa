{
  "name": "sejaatendido-pwa",
  "version": "2.0.0",
  "private": true,
  "description": "Seja Atendido – PWA Web App",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check:unused": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "sandbox:up": "docker compose -f docker-compose.staging.yml up -d --build",
    "sandbox:down": "docker compose -f docker-compose.staging.yml down",
    "sandbox:logs": "docker compose -f docker-compose.staging.yml logs -f",
    "sandbox:build": "docker compose -f docker-compose.staging.yml build"
  },
  "dependencies": {
    "@mercadopago/sdk-react": "^1.0.7",
    "axios": "^1.7.9",
    "jsqr": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "msw": "^2.14.6",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
